# Copy to .env and fill in. NEVER commit .env - it is gitignored.
WEBEX_BOT_TOKEN=<paste-webex-bot-token-here>
# Optional: pin one space id; leave empty to auto-discover every space the bot is in
WEBEX_ROOM_ID=

# Optional: stream every cloud event to Splunk via HTTP Event Collector.
# Leave both empty to keep Splunk forwarding fully disabled (default).
# Example with a local Splunk container: SPLUNK_HEC_URL=http://host.docker.internal:8088
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Drone integration. Mock mode is fully functional and needs no hardware.
DRONE_MODE=mock
DRONE_CONTROL_KEY=change-this-shared-drone-control-key

# Only required when DRONE_MODE=flytbase. Use the URL, token and endpoint
# paths issued for your FlytBase tenant; do not expose them to browser code.
FLYTBASE_API_BASE_URL=
FLYTBASE_API_TOKEN=
FLYTBASE_DRONES_PATH=/drones
FLYTBASE_MISSIONS_PATH=/missions
