# SANJEEVANI runs without environment secrets by default.
# Copy this file to .env only if you add optional integrations later.

# Optional integration scripts should target the cloud API or a pod API.
CLOUD_API_URL=http://localhost:9000
DEFAULT_POD_URL=http://localhost:8001
MONGODB_URI=mongodb://localhost:27017/sanjeevani-command-center

# Optional Cisco Meraki Dashboard integration.
MERAKI_API_KEY=
MERAKI_ORG_ID=

# Optional Cisco IOS-XE RESTCONF integration.
IOSXE_HOST=sandbox-iosxe-latest-1.cisco.com
IOSXE_USER=developer
IOSXE_PASS=
