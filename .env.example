# Copy to .env and fill in. NEVER commit .env - it is gitignored.
WEBEX_BOT_TOKEN=NzM0ODA2MjctMTIzNS00ZDg0LWJmODEtYzA5NTRjZGVhNjUyMDFkNDg0MjctNWMw_P0A1_5bfdaf80-ff6c-4415-b1a5-9c0e479592eb
# Optional: pin one space id; leave empty to auto-discover every space the bot is in
WEBEX_ROOM_ID=

# Optional: stream every cloud event to Splunk via HTTP Event Collector.
# Leave both empty to keep Splunk forwarding fully disabled (default).
# Example with a local Splunk container: SPLUNK_HEC_URL=http://host.docker.internal:8088
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
